# ============================================================
# Neuro — .gitattributes
# ============================================================

# Default: normalize line endings to LF on checkin
* text=auto eol=lf

# ------------------------------------------------------------
# Web / Next.js
# ------------------------------------------------------------
*.ts    text eol=lf diff=typescript
*.tsx   text eol=lf diff=typescript
*.js    text eol=lf diff=javascript
*.jsx   text eol=lf diff=javascript
*.mjs   text eol=lf diff=javascript
*.cjs   text eol=lf diff=javascript
*.json  text eol=lf
*.css   text eol=lf diff=css
*.md    text eol=lf diff=markdown
*.mdx   text eol=lf diff=markdown
*.html  text eol=lf diff=html
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf

# ------------------------------------------------------------
# Swift / macOS app
# ------------------------------------------------------------
*.swift      text eol=lf diff=swift
*.xcconfig   text eol=lf
*.plist      text eol=lf
*.entitlements text eol=lf
*.storyboard linguist-generated=true
*.xib        linguist-generated=true

# ------------------------------------------------------------
# Binary files — never diff or merge
# ------------------------------------------------------------
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.svg    text eol=lf
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary
*.pdf    binary
*.zip    binary
*.tar.gz binary
*.xcassets linguist-generated=true

# ------------------------------------------------------------
# Linguist overrides (GitHub language stats)
# ------------------------------------------------------------
website/node_modules/** linguist-vendored=true
website/public/**       linguist-documentation=true
