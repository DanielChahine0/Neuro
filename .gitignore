# ============================================================
# Neuro — Root .gitignore
# Covers: Node.js/Next.js, Xcode/Swift, Firebase, macOS, editors
# ============================================================

# ------------------------------------------------------------
# macOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
*.icloud

# ------------------------------------------------------------
# Node.js / npm (root workspace)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnp.*
package-lock.json
# Note: website/package-lock.json is tracked; root lock is not needed

# ------------------------------------------------------------
# Next.js (website/)
# (website/.gitignore handles most of these, but keep here for safety)
# ------------------------------------------------------------
website/.next/
website/out/
website/build/
website/.vercel
website/next-env.d.ts
*.tsbuildinfo
coverage/

# ------------------------------------------------------------
# Xcode / Swift (macOS app — future)
# ------------------------------------------------------------
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
xcuserdata/
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM
*.xcarchive
*.xcresult
Pods/
.swiftpm/config/registries.json
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
.netrc

# ------------------------------------------------------------
# Firebase
# ------------------------------------------------------------
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log
.firebaserc
# Note: firebase.json IS tracked (project config, not secrets)

# ------------------------------------------------------------
# Environment & secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.p8
*.mobileprovision
GoogleService-Info.plist
google-services.json
AuthKey_*.p8

# ------------------------------------------------------------
# Editors
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.nova/

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
.cache/
dist/
